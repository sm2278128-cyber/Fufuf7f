{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Creative projects showcasing graphic design, banners, posters, and video edits",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the creative project" },
        "description": { "type": "string", "description": "General description and creative elements" },
        "category": { "type": "string", "description": "The primary category e.g. Design, Banner, Video, Branding" },
        "mediaList": {
          "type": "array",
          "description": "A set of media objects",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["image", "video"] },
              "url": { "type": "string" }
            },
            "required": ["type", "url"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description", "category", "mediaList", "createdAt"]
    },
    "Skill": {
      "title": "Skill",
      "description": "Professional skills and tools used by Umang Creation",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The skill name" },
        "displayIcon": { "type": "string", "description": "Name of the Lucide-react icon identifier" },
        "rating": { "type": "number", "description": "Expertise level from 0 to 100" },
        "category": { "type": "string", "description": "Grouping category e.g. Core, Secondary" }
      },
      "required": ["name", "displayIcon", "rating", "category"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects published by the curator"
    },
    "/skills/{skillId}": {
      "schema": "Skill",
      "description": "Collection of custom creative skills showcased on the skills tab"
    }
  }
}
